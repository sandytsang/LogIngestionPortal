{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://sandytsang.github.io/LogIngestionPortal/category.schema.json",
  "title": "Log Ingestion Portal category file",
  "type": "object",
  "additionalProperties": false,
  "required": ["category", "fields"],
  "properties": {
    "category": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40,
      "description": "Display name of the category this file contributes."
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/field" }
    }
  },
  "definitions": {
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "order", "default", "setups", "column"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9]*$",
          "maxLength": 60,
          "description": "Unique identifier; must be a valid PowerShell variable-name fragment."
        },
        "label": { "type": "string", "minLength": 1, "maxLength": 60 },
        "order": { "type": "integer", "minimum": 0, "maximum": 100000 },
        "default": { "type": "boolean" },
        "locked": { "type": "boolean" },
        "setups": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9]*$" }
        },
        "expression": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "collector": { "type": "string", "minLength": 1, "maxLength": 8000 },
        "element": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["expression", "column"],
            "properties": {
              "expression": { "type": "string", "minLength": 1, "maxLength": 1000 },
              "column": { "$ref": "#/definitions/column" }
            }
          }
        },
        "column": { "$ref": "#/definitions/column" }
      },
      "oneOf": [
        { "required": ["expression"], "not": { "required": ["collector"] } },
        { "required": ["collector"], "not": { "required": ["expression"] } }
      ]
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "description"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$",
          "maxLength": 60,
          "description": "Log Analytics column name."
        },
        "type": {
          "type": "string",
          "enum": ["string", "int", "long", "real", "boolean", "datetime", "dynamic", "guid"]
        },
        "description": { "type": "string", "minLength": 1, "maxLength": 300 }
      }
    }
  }
}
