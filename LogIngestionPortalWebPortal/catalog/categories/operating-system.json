{
  "category": "Operating system",
  "fields": [
    {
      "id": "OSVersion",
      "label": "OS version",
      "order": 5,
      "default": true,
      "setups": ["os"],
      "expression": "\"$($os.Caption) $($os.Version)\"",
      "column": { "name": "OSVersion", "type": "string", "description": "Operating system build/version string." }
    },
    {
      "id": "OSBuildNumber",
      "label": "OS build number",
      "order": 16,
      "default": false,
      "setups": ["os"],
      "expression": "\"$($os.BuildNumber)\"",
      "column": {
        "name": "OSBuildNumber",
        "type": "string",
        "description": "Operating system build number (Win32_OperatingSystem.BuildNumber)."
      }
    },
    {
      "id": "OSArchitecture",
      "label": "OS architecture",
      "order": 17,
      "default": false,
      "setups": ["os"],
      "expression": "$os.OSArchitecture",
      "column": {
        "name": "OSArchitecture",
        "type": "string",
        "description": "Operating system architecture (e.g. 64-bit)."
      }
    },
    {
      "id": "LastBootTime",
      "label": "Last boot time",
      "order": 18,
      "default": false,
      "setups": ["os"],
      "expression": "if ($os.LastBootUpTime) { $os.LastBootUpTime.ToUniversalTime().ToString('o') } else { $null }",
      "column": { "name": "LastBootTime", "type": "datetime", "description": "Last system boot time (UTC)." }
    },
    {
      "id": "Domain",
      "label": "Domain / workgroup",
      "order": 19,
      "default": false,
      "setups": ["cs"],
      "expression": "$cs.Domain",
      "column": {
        "name": "Domain",
        "type": "string",
        "description": "AD domain or workgroup the device belongs to."
      }
    },
    {
      "id": "PartOfDomain",
      "label": "Domain joined",
      "order": 20,
      "default": false,
      "setups": ["cs"],
      "expression": "[bool]$cs.PartOfDomain",
      "column": {
        "name": "PartOfDomain",
        "type": "boolean",
        "description": "Whether the device is joined to an AD domain."
      }
    },
    {
      "id": "ComputerUpTimeDays",
      "label": "Computer uptime (days)",
      "order": 44,
      "default": false,
      "setups": ["os"],
      "expression": "if ($os.LastBootUpTime) { [int](New-TimeSpan -Start $os.LastBootUpTime -End (Get-Date)).Days } else { $null }",
      "column": {
        "name": "ComputerUpTimeDays",
        "type": "int",
        "description": "Days since last boot (derived from Win32_OperatingSystem.LastBootUpTime)."
      }
    },
    {
      "id": "InstallDate",
      "label": "OS install date",
      "order": 45,
      "default": false,
      "setups": ["os"],
      "expression": "if ($os.InstallDate) { $os.InstallDate.ToUniversalTime().ToString('o') } else { $null }",
      "column": {
        "name": "InstallDate",
        "type": "datetime",
        "description": "Operating system install date (Win32_OperatingSystem.InstallDate, UTC)."
      }
    },
    {
      "id": "WindowsVersion",
      "label": "Windows version (display)",
      "order": 46,
      "default": false,
      "setups": [],
      "collector": "$cv = 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion'\n$dv = (Get-ItemProperty -Path $cv -Name DisplayVersion -ErrorAction SilentlyContinue).DisplayVersion\nif ([string]::IsNullOrEmpty($dv)) { (Get-ItemProperty -Path $cv -Name ReleaseId -ErrorAction SilentlyContinue).ReleaseId } else { $dv }",
      "column": {
        "name": "WindowsVersion",
        "type": "string",
        "description": "Windows feature-update version (e.g. 22H2) from CurrentVersion\\DisplayVersion (fallback ReleaseId)."
      }
    },
    {
      "id": "OSName",
      "label": "OS name",
      "order": 47,
      "default": false,
      "setups": ["os"],
      "expression": "$os.Caption",
      "column": {
        "name": "OSName",
        "type": "string",
        "description": "Operating system product name (Win32_OperatingSystem.Caption)."
      }
    },
    {
      "id": "OSRevision",
      "label": "OS revision (UBR)",
      "order": 48,
      "default": false,
      "setups": [],
      "collector": "(Get-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion' -Name UBR -ErrorAction SilentlyContinue).UBR",
      "column": {
        "name": "OSRevision",
        "type": "int",
        "description": "OS update build revision (CurrentVersion\\UBR), the patch number after the build."
      }
    },
    {
      "id": "ComputerInfo",
      "label": "Computer info",
      "order": 100,
      "default": false,
      "setups": [],
      "collector": "Get-ComputerInfo | Select-Object OsName, OsVersion, OsBuildNumber, OsArchitecture, WindowsProductName, WindowsVersion, CsManufacturer, CsModel, CsName, BiosManufacturer, BiosVersion",
      "column": {
        "name": "ComputerInfo",
        "type": "dynamic",
        "description": "Selected Get-ComputerInfo properties (OS, Windows, manufacturer/model, BIOS) as a JSON object."
      }
    }
  ]
}
