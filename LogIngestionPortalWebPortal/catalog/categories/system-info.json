{
  "category": "System info",
  "fields": [
    {
      "id": "FqdnHostname",
      "label": "FQDN hostname",
      "order": 84,
      "default": false,
      "setups": ["cs"],
      "expression": "if ($cs.Domain) { \"$env:COMPUTERNAME.$($cs.Domain)\" } else { $env:COMPUTERNAME }",
      "column": { "name": "FqdnHostname", "type": "string", "description": "Fully qualified host name (computer name + AD domain from Win32_ComputerSystem.Domain)." }
    },
    {
      "id": "WindowsDomainRole",
      "label": "Windows domain role",
      "order": 85,
      "default": false,
      "setups": ["cs"],
      "expression": "switch ([int]$cs.DomainRole) { 0 { 'StandaloneWorkstation' } 1 { 'MemberWorkstation' } 2 { 'StandaloneServer' } 3 { 'MemberServer' } 4 { 'BackupDomainController' } 5 { 'PrimaryDomainController' } default { 'Unknown' } }",
      "column": { "name": "WindowsDomainRole", "type": "string", "description": "Domain membership role (Win32_ComputerSystem.DomainRole) decoded to a label." }
    }
  ]
}
